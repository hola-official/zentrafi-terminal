    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "overrides": {
    "@zentrafi/sdk-v2": {
      "@zentrafi/sdk-core": "^1.0.0"
    }
  },
  "resolutions": {
    "@zentrafi/sdk-core": "^1.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "tsc --project tsconfig.lib.json",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@rainbow-me/rainbowkit": ">=2.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
