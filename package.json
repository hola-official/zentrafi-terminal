    "@radix-ui/react-tooltip": "1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-query": "^5.90.11",
    "@zentrafi/sdk-core": "^1.0.0",
    "@zentrafi/sdk-v2": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "15.3.8",
