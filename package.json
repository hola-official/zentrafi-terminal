{
  "name": "@zentrafi/terminal",
  "version": "1.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Embeddable swap terminal for ZentraFi on Pharos EVM",
  "license": "MIT",
  "author": "ZentraFi",
  "keywords": [
    "zentrafi",
    "pharos",
    "swap",
    "dex",
    "terminal",
    "widget",
    "defi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Zentra-Finance/zentrafi-terminal"
  },
  "homepage": "https://x.zentrafi.xyz",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css",
    "./dist/styles.css": "./dist/styles.css",
    "./dist/style.css": "./dist/styles.css",
    "./cdn": "./dist/cdn/main.js"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "overrides": {
    "@zentrafi/sdk-v2": {
      "@zentrafi/sdk-core": "^1.0.0"
    }
  },
  "resolutions": {
    "@zentrafi/sdk-core": "^1.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cdn": "vite build --config vite.config.cdn.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:types": "tsc --project tsconfig.lib.json --emitDeclarationOnly --noEmit false",
    "build:all": "npm run build:cdn && npm run build:lib && npm run build:types",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@rainbow-me/rainbowkit": ">=2.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-tooltip": "1.2.8",
    "@zentrafi/sdk-core": "^1.0.0",
    "@zentrafi/sdk-v2": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "next": "15.3.8",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "viem": "^2.47.6",
    "wagmi": "^2.0.0",
    "vite": "^6.4.1"
  }
}
