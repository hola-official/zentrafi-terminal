{
  "name": "@zentrafi/terminal",
  "version": "0.1.0",
  "description": "Embeddable swap terminal for ZentraFi on Pharos EVM",
  "license": "MIT",
  "author": "ZentraFi",
  "keywords": [
    "zentrafi",
    "pharos",
    "swap",
    "dex",
    "terminal",
    "widget",
    "defi"
  ],
  "repository": {
    "type": "git",
